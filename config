set $mod Mod4

# --- CONFIGURACIÓN DE ENTRADA (Teclado Inglés Internacional) ---
input "type:keyboard" {
    xkb_layout "us"
    xkb_variant "intl"
}

# --- ATRIBUTOS DE TECLAS DE HARDWARE (Brillo, Sonido y Micrófono) ---
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym XF86KbdBrightnessUp exec brightnessctl --device='*kbdbacklight' set +10%
bindsym XF86KbdBrightnessDown exec brightnessctl --device='*kbdbacklight' set 10%-

# Ajustes precisos (1%) con la tecla ALT
bindsym Mod1+XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+
bindsym Mod1+XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-
bindsym Mod1+XF86MonBrightnessUp exec brightnessctl set +1%
bindsym Mod1+XF86MonBrightnessDown exec brightnessctl set 1%-

# Control de reproducción en VLC/Navegador
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

# --- COMPONENTES DEL ENTORNO EN SEGUNDO PLANO ---
exec udiskie --tray
exec nm-applet --indicator
exec blueman-applet
exec mako
exec /usr/lib/x86_64-linux-gnu/libexec/polkit-kde-authentication-agent-1

# --- ATAJOS DEL SISTEMA ---
set $term kitty
set $menu fuzzel
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu

# Lanzar configurador gráfico de pantallas externas (wdisplays)
bindsym $mod+Shift+p exec wdisplays

bar {
    swaybar_command waybar
}

include /etc/sway/config.d/*
